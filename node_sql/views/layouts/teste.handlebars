<br><br><br>
<h2>Lista de Dados</h2>

<div class="container">
    <a href="/" class="btn btn-primary mb-3">Adicionar</a>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th scope="col">#ID</th>
                <th scope="col">Nome</th>
                <th scope="col">E-mail</th>
                <th scope="col">Senha</th>
                <th scope="col">Ações</th>
            </tr>
        </thead>
        <tbody>
            {{#each teste}}
            <tr>
                <th scope="row">{{this.id}}</th>
                <td>{{this.nome}}</td>
                <td>{{this.email}}</td>
                <td>{{this.senha}}</td>
                <td>
                    <a href="/teste/edit/{{this.id}}" class="btn btn-warning btn-sm">Editar</a>

                    <form action="/teste/remove/{{this.id}}" method="POST" style="display:inline;" onsubmit="return confirm('Davi, deseja excluir?')">
                        <button type="submit" class="btn btn-danger btn-sm">Excluir</button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>